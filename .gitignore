__pycache__/
*.egg-info/
*.pyc
.idea/
.DS_Store
out/
*.cPickle
*.dill

# Cython / C-extension build artifacts (parca Cython extensions)
*.so
*.c
build/
v2ecoli/processes/parca/**/*.cpython-*.so

# Worktree-local runtime (server, venv symlinks, logs, scheduled-task locks,
# per-run dashboard artefacts). Schemas under .pbg/schemas/ stay tracked.
.venv
.pbg/*
!.pbg/schemas/
investigations/*/runs.db
investigations/*/viz/
investigations/*/.run.lock
# Dashboard re-render targets (regenerated on demand by /api/render)
reports/assets/*
!reports/assets/.keep
